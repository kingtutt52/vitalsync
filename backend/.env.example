# Copy this file to .env and fill in real values before running locally.

# Database — matches docker-compose defaults
DATABASE_URL=postgresql://vitalsync:vitalsync@localhost:5432/vitalsync

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Local file storage root (relative to backend dir)
STORAGE_ROOT=./storage

# Stripe (test mode)
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Create products + prices in Stripe dashboard and paste IDs here
STRIPE_PRICE_PREMIUM_LITE=price_PREMIUM_LITE_ID
STRIPE_PRICE_VITAL_PLUS=price_VITAL_PLUS_ID
STRIPE_PRICE_VITAL_PRO=price_VITAL_PRO_ID

# Base URL for Stripe redirect after checkout
APP_BASE_URL=http://localhost:3000
